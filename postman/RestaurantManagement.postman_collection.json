{
  "info": {
    "name": "Restaurant Management - Fase 2",
    "description": "Runs top-to-bottom in the Collection Runner against a freshly started app with an empty database. Every request asserts its expected status. State (userId, token, restaurantId, menuItemId, ...) is chained via environment variables set in each request's Tests script - nothing is hardcoded except the two seeded UserType UUIDs (donoTypeId/clienteTypeId), documented in the environment file. Safe to run more than once against the same database: a collection-level pre-request script generates a unique runSuffix once per run, used in every email/login/nome that must be unique.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get(\"runSuffix\")) {\n    pm.environment.set(\"runSuffix\", Date.now().toString());\n}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup - Dono de Restaurante",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 201\", () => pm.response.to.have.status(201));\nconst json = pm.response.json();\npm.test(\"captures userId and donoLogin\", () => {\n    pm.expect(json.id).to.be.a(\"string\");\n    pm.environment.set(\"userId\", json.id);\n    pm.environment.set(\"donoLogin\", json.login);\n});\npm.test(\"userType is Dono de Restaurante\", () => {\n    pm.expect(json.userType.id).to.eql(pm.environment.get(\"donoTypeId\"));\n});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Dono Principal\",\n  \"email\": \"dono.{{runSuffix}}@example.com\",\n  \"login\": \"dono.{{runSuffix}}\",\n  \"senha\": \"senha123\",\n  \"endereco\": \"Rua A, 100\",\n  \"userTypeId\": \"{{donoTypeId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/v1/users", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users"] }
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 200\", () => pm.response.to.have.status(200));\nconst json = pm.response.json();\npm.test(\"captures token\", () => {\n    pm.expect(json.accessToken).to.be.a(\"string\");\n    pm.environment.set(\"token\", json.accessToken);\n});\npm.test(\"tokenType is Bearer\", () => pm.expect(json.tokenType).to.eql(\"Bearer\"));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"{{donoLogin}}\",\n  \"senha\": \"senha123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] }
          },
          "response": []
        }
      ]
    },
